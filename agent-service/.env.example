# Agent Service — Default Environment
# Copy to .env.development.local and fill in real values
PORT=3000
WORKSPACE_DIR=/workspace/app
LOGS_DIR=/home/ubuntu/.cyrus
CLAUDE_PROJECTS_DIR=/home/ubuntu/.claude/projects
CLAUDE_MODEL=opus
MAX_TURNS=200

# Sent from orchestrator
LINEAR_OAUTH_ACCESS_TOKEN=
ORCHESTRATOR_URL=
GITHUB_TOKEN=
GH_TOKEN=

# === Required ===

# GitHub PAT with repo scope — https://github.com/settings/tokens
GITHUB_TOKEN=

# Your domain for the orchestrator (e.g. hermes.example.com)
# Must be a domain with DNS managed by Cloudflare
CLOUDFLARE_HOSTNAME=

# Linear OAuth app — see docs/linear.md for setup steps
# Create at: Linear Settings → API → OAuth Applications → New
LINEAR_WEBHOOK_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Claude auth (pick one)
# OAuth token from Claude Code CLI, or API key from console.anthropic.com
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# === GitHub App (optional, recommended) ===
# Short-lived tokens with auto-refresh — see docs/github.md
# If set, orchestrator uses these instead of GITHUB_TOKEN for agent operations.
# GITHUB_TOKEN is still required above for the initial repo clone during setup.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_INSTALLATION_ID=
# Multi-line PEM key — wrap in double quotes:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
# MIIEpAIBAAKCAQEA...
# -----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=

# === Slack (optional) ===
# See docs/slack.md for setup steps
# Create at: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# === Optional defaults ===
CLOUDFLARE_TUNNEL_NAME=hermes

# === Preview URLs (optional) ===
# Only needed if you want live preview deployments per session
# See docs/cloudflare.md (Part B) for setup steps
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
